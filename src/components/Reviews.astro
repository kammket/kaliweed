---
const reviews = [
  { name: "Markus T.", rating: 5, text: "Beste Qualität die ich je hatte. Cali Weed Packs kamen original verpackt und der Geschmack ist unglaublich.", date: "25. Januar 2026" },
  { name: "Sarah K.", rating: 5, text: "Schnelle Lieferung, diskret verpackt. Der Wizard Trees Strain ist ein absolutes Highlight!", date: "18. Februar 2026" },
  { name: "Thomas B.", rating: 5, text: "Seit ich hier bestelle, kaufe ich nirgendwo anders mehr. Top Qualität und fairer Preis.", date: "5. März 2026" },
  { name: "Julia M.", rating: 4, text: "Alien Labs Zangria war genau wie beschrieben. Sehr intensives Aroma und starke Wirkung.", date: "12. März 2026" },
  { name: "Leon H.", rating: 5, text: "Backpack Boyz Oreoz ist mein absoluter Favorit. Premium-Qualität wie aus dem Dispensary.", date: "20. März 2026" },
  { name: "Anna S.", rating: 5, text: "Hervorragender Kundenservice und einwandfreie Produkte. Kann ich nur empfehlen!", date: "28. März 2026" },
];
---
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  {reviews.map((review) => (
    <div class="bg-surface-light border border-white/5 rounded-2xl p-6 hover:border-gold/20 transition-colors" itemscope itemtype="https://schema.org/Review">
      <div class="flex items-center gap-1 mb-3">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg class={`w-4 h-4 ${i < review.rating ? 'text-gold' : 'text-white/10'}`} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        ))}
        <span itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
          <meta itemprop="ratingValue" content={review.rating.toString()} />
        </span>
      </div>
      <p itemprop="reviewBody" class="text-text-secondary text-sm leading-relaxed mb-4">{review.text}</p>
      <div class="flex items-center justify-between">
        <span itemprop="author" class="text-white font-semibold text-sm">{review.name}</span>
        <span class="text-text-secondary text-xs">{review.date}</span>
      </div>
      <div class="flex items-center gap-1 mt-2">
        <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        <span class="text-success text-xs font-medium">Verifizierter Kauf</span>
      </div>
    </div>
  ))}
</div>
