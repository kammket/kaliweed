            </span>
            <span class="text-text-secondary hover:text-gold cursor-pointer transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </span>
          </div>
        </div>
        <div>
          <h3 class="text-white text-sm font-bold uppercase tracking-wider mb-4">Kategorien</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/kategorie/wizard-trees" class="text-text-secondary hover:text-gold transition-colors">Wizard Trees Kaufen</a></li>
            <li><a href="/kategorie/jungle-boys-weed" class="text-text-secondary hover:text-gold transition-colors">Jungle Boys Weed</a></li>
            <li><a href="/kategorie/backpack-boyz-weed" class="text-text-secondary hover:text-gold transition-colors">Backpack Boyz Weed</a></li>
            <li><a href="/kategorie/ten-co-weed" class="text-text-secondary hover:text-gold transition-colors">TEN Co Weed</a></li>
            <li><a href="/kategorie/alien-labs-weed" class="text-text-secondary hover:text-gold transition-colors">Alien Labs Weed</a></li>
            <li><a href="/kategorie/doja-weed" class="text-text-secondary hover:text-gold transition-colors">Doja Weed</a></li>
            <li><a href="/kategorie/cannabis-kaufen" class="text-text-secondary hover:text-gold transition-colors">Cannabis Kaufen</a></li>
            <li><a href="/cannabis-online-kaufen" class="text-text-secondary hover:text-gold transition-colors">Cannabis Online Kaufen</a></li>
            <li><a href="/thc-blueten-kaufen" class="text-text-secondary hover:text-gold transition-colors">THC Blüten Kaufen</a></li>
            <li><a href="/premium-gras-bestellen" class="text-text-secondary hover:text-gold transition-colors">Premium Gras Bestellen</a></li>
            <li><a href="/jungle-boys-weed-kaufen" class="text-text-secondary hover:text-gold transition-colors">Jungle Boys Weed Kaufen</a></li>
            <li><a href="/backpack-boyz-weed-kaufen" class="text-text-secondary hover:text-gold transition-colors">Backpack Boyz Weed Kaufen</a></li>
            <li><a href="/wizard-trees-weed-kaufen" class="text-text-secondary hover:text-gold transition-colors">Wizard Trees Weed Kaufen</a></li>
            <li><a href="/indica-vs-sativa" class="text-text-secondary hover:text-gold transition-colors">Indica vs Sativa</a></li>
            <li><a href="/cannabis-versand-deutschland" class="text-text-secondary hover:text-gold transition-colors">Cannabis Versand</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-white text-sm font-bold uppercase tracking-wider mb-4">Information</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/cali-weed-sorten" class="text-text-secondary hover:text-gold transition-colors">Cali Weed Sorten</a></li>
            <li><a href="/cali-weed-wirkung" class="text-text-secondary hover:text-gold transition-colors">Cali Weed Wirkung</a></li>
            <li><a href="/cali-weed-packs" class="text-text-secondary hover:text-gold transition-colors">Cali Weed Packs</a></li>
            <li><a href="/topshelf-gras" class="text-text-secondary hover:text-gold transition-colors">Topshelf Gras</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-white text-sm font-bold uppercase tracking-wider mb-4">Vertrauen & Sicherheit</h3>
          <div class="space-y-3">
            <div class="flex items-center gap-2 text-sm text-text-secondary">
              <svg class="w-5 h-5 text-success flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              Sichere Bezahlung
            </div>
            <div class="flex items-center gap-2 text-sm text-text-secondary">
              <svg class="w-5 h-5 text-success flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
              Diskreter Versand
            </div>
            <div class="flex items-center gap-2 text-sm text-text-secondary">
              <svg class="w-5 h-5 text-success flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Geprüfte Qualität
            </div>
            <div class="flex items-center gap-2 text-sm text-text-secondary">
              <svg class="w-5 h-5 text-success flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
