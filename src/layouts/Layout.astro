---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: object;
}

const { title, description, canonical, ogImage = '/images/og-default.webp', jsonLd } = Astro.props;
const siteUrl = 'https://caliweedkaufen.de';
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${Astro.url.pathname}`;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:site_name" content="Cali Weed Kaufen" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}
</head>
<body class="min-h-screen flex flex-col">
  <header class="sticky top-0 z-50 bg-primary/95 backdrop-blur-md border-b border-white/5">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 md:h-20">
        <a href="/" class="flex items-center gap-2 group" aria-label="Startseite">
          <span class="text-xl md:text-2xl font-black text-gold tracking-tight group-hover:text-gold-dark transition-colors">CALI WEED</span>
          <span class="text-xs md:text-sm text-text-secondary font-semibold uppercase tracking-widest">Kaufen</span>
        </a>

        <button id="mobile-menu-btn" class="md:hidden p-2 text-text-secondary hover:text-white" aria-label="Menü öffnen">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>

        <div class="hidden md:flex items-center gap-6 text-sm font-medium">
          <a href="/" class="text-text-secondary hover:text-gold transition-colors">Start</a>
          <a href="/shop" class="text-text-secondary hover:text-gold transition-colors">Shop</a>
          <a href="/kategorie/wizard-trees" class="text-text-secondary hover:text-gold transition-colors">Wizard Trees</a>
          <a href="/kategorie/jungle-boys-weed" class="text-text-secondary hover:text-gold transition-colors">Jungle Boys</a>
          <a href="/kategorie/backpack-boyz-weed" class="text-text-secondary hover:text-gold transition-colors">Backpack Boyz</a>
          <a href="/kategorie/cali-weed-packs-kaufen" class="text-text-secondary hover:text-gold transition-colors">Cali Packs</a>
          <a href="/warenkorb" class="relative bg-gold hover:bg-gold-dark text-primary font-bold px-4 py-2 rounded-lg transition-colors flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
            Warenkorb
            <span id="cart-count-desktop" class="hidden absolute -top-2 -right-2 bg-red-500 text-white text-xs w-5 h-5 rounded-full flex items-center justify-center font-bold">0</span>
          </a>
        </div>
      </div>

      <div id="mobile-menu" class="hidden md:hidden pb-4">
        <div class="flex flex-col gap-2">
          <a href="/" class="px-3 py-2 text-text-secondary hover:text-gold hover:bg-white/5 rounded-lg transition-colors">Start</a>
          <a href="/shop" class="px-3 py-2 text-text-secondary hover:text-gold hover:bg-white/5 rounded-lg transition-colors">Shop</a>
          <a href="/kategorie/wizard-trees" class="px-3 py-2 text-text-secondary hover:text-gold hover:bg-white/5 rounded-lg transition-colors">Wizard Trees</a>
          <a href="/kategorie/jungle-boys-weed" class="px-3 py-2 text-text-secondary hover:text-gold hover:bg-white/5 rounded-lg transition-colors">Jungle Boys</a>
          <a href="/kategorie/backpack-boyz-weed" class="px-3 py-2 text-text-secondary hover:text-gold hover:bg-white/5 rounded-lg transition-colors">Backpack Boyz</a>
          <a href="/kategorie/cali-weed-packs-kaufen" class="px-3 py-2 text-text-secondary hover:text-gold hover:bg-white/5 rounded-lg transition-colors">Cali Packs</a>
          <a href="/warenkorb" class="px-3 py-2 bg-gold text-primary font-bold rounded-lg text-center">Warenkorb</a>
        </div>
      </div>
    </nav>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="bg-primary border-t border-white/5 mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
        <div>
          <h3 class="text-gold text-lg font-bold mb-4">Cali Weed Kaufen</h3>
          <p class="text-text-secondary text-sm leading-relaxed">Premium Cali Weed und Cali Weed Packs in Deutschland online kaufen. Authentische Qualität aus Kalifornien mit diskretem Versand.</p>
