---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  { question: "Was macht Wizard Trees Weed besonders?", answer: "Wizard Trees steht für exklusive In-House-Genetiken, außergewöhnliche Aromen und kompromisslose Qualität." },
  { question: "Welche Sorten sind am beliebtesten?", answer: "Wizzy, Black Light und Studio 54 sind besonders gefragt. Jede Sorte überzeugt durch einzigartiges Terpenprofil." },
  { question: "Wie erkenne ich echtes Wizard Trees Weed?", answer: "Achte auf die Verpackung, das Aroma und die dichte Trichom-Schicht. Originale Produkte sind limitiert und begehrt." },
];
---
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
<Layout
  title="Wizard Trees Weed Kaufen | Premium Strains & Packs"
  description="Wizard Trees Weed kaufen ✓ Exklusive Strains ✓ Premium Cali Weed ✓ Tipps zur Auswahl & Erkennung von original Wizard Trees Produkten."
  canonical="/wizard-trees-weed-kaufen"
  jsonLd={jsonLd}
>
  <section class="bg-gradient-to-br from-primary via-secondary to-accent py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-3xl md:text-5xl font-black text-white mb-6">Wizard Trees Weed Kaufen</h1>
        <p class="text-text-secondary text-lg leading-relaxed">Entdecke Wizard Trees Strains und Packs. Tipps zur Auswahl, Qualität und worauf du beim Kauf achten solltest.</p>
      </div>
    </div>
  </section>
  <FAQ items={faqItems} />
</Layout>
