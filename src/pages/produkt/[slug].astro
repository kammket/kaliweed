---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products, getProductBySlug, getProductsByCategory } from '../../data/products';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const product = getProductBySlug(slug as string);

if (!product) {
  return Astro.redirect('/shop');
}

const relatedProducts = getProductsByCategory(product.categorySlug)
  .filter((p) => p.id !== product.id)
  .slice(0, 4);

const minPrice = Math.min(...product.variations.map((v) => v.price));
const maxPrice = Math.max(...product.variations.map((v) => v.price));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.description,
  "image": product.image,
  "brand": { "@type": "Brand", "name": product.category },
  "offers": {
    "@type": "AggregateOffer",
    "lowPrice": minPrice,
    "highPrice": maxPrice,
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock",
    "offerCount": product.variations.length
  }
};
---
<Layout
  title={`${product.name} | ${product.category} | Cali Weed Kaufen`}
  description={`${product.name} von ${product.category} kaufen ✓ THC ${product.thc} ✓ Ab €${minPrice} ✓ Premium Cali Weed ✓ Diskreter Versand`}
  canonical={`/produkt/${product.slug}`}
  jsonLd={jsonLd}
>
  <!-- Breadcrumb -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
    <nav class="text-sm text-text-secondary">
      <a href="/" class="hover:text-gold transition-colors">Startseite</a>
      <span class="mx-2">/</span>
      <a href="/shop" class="hover:text-gold transition-colors">Shop</a>
      <span class="mx-2">/</span>
      <a href={`/kategorie/${product.categorySlug}`} class="hover:text-gold transition-colors">{product.category}</a>
      <span class="mx-2">/</span>
      <span class="text-white">{product.name}</span>
    </nav>
  </div>

  <!-- Product Detail -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Product Image -->
      <div class="bg-surface-light rounded-2xl border border-white/5 overflow-hidden aspect-square flex items-center justify-center">
        <img
          src={product.image}
          alt={product.name}
          class="w-full h-full object-cover object-center transition-opacity duration-300"
          loading="lazy"
          onError="this.style.display='none'; this.parentNode.querySelector('.fallback-emoji').style.display='flex';"
        />
        <div class="w-full h-full flex items-center justify-center fallback-emoji" style="display:none;">
          <span class="text-8xl mb-4 opacity-30">🌿</span>
        </div>
      </div>

      <!-- Product Info -->
      <div>
        <span class="inline-block bg-gold/10 text-gold text-xs font-semibold px-3 py-1 rounded-full mb-3">{product.category}</span>
        <h1 class="text-3xl md:text-4xl font-black text-white mb-4">{product.name}</h1>
        
        <div class="flex items-center gap-4 mb-6">
          <div class="flex items-center gap-1">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
            <span class="text-text-secondary text-sm ml-1">(4.9)</span>
          </div>
          {product.thc && <span class="bg-success/10 text-success text-xs font-bold px-3 py-1 rounded-full">THC: {product.thc}</span>}
          {product.type && <span class="bg-blue-500/10 text-blue-400 text-xs font-bold px-3 py-1 rounded-full">{product.type}</span>}
        </div>

        <p class="text-text-secondary leading-relaxed mb-6">{product.description}</p>

        <!-- Price -->
        <div class="mb-6">
          <span class="text-3xl font-black text-gold" id="current-price">€{product.variations[0].price.toFixed(2)}</span>
          <span class="text-text-secondary text-sm ml-2">inkl. MwSt.</span>
        </div>

        <!-- Variation Selector -->
        <div class="mb-6">
          <label class="block text-white font-semibold mb-3">Menge wählen:</label>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" id="variation-selector">
            {product.variations.map((v, i) => (
              <button
                data-price={v.price}
                data-weight={v.weight}
                data-index={i}
                class={`variation-btn border rounded-xl p-3 text-center transition-all ${i === 0 ? 'border-gold bg-gold/10 text-white' : 'border-white/10 text-text-secondary hover:border-gold/30'}`}
              >
                <span class="block font-bold text-sm">{v.weight}</span>
                <span class="block text-gold font-bold mt-1">€{v.price.toFixed(2)}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- Add to Cart -->
        <button id="add-to-cart" class="w-full bg-gold hover:bg-gold-dark text-primary font-bold py-4 rounded-xl transition-colors text-lg flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
          In den Warenkorb
        </button>

        <!-- Trust -->
        <div class="grid grid-cols-2 gap-3 mt-6">
          <div class="flex items-center gap-2 text-text-secondary text-sm"><svg class="w-4 h-4 text-success" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>Sichere Bezahlung</div>
          <div class="flex items-center gap-2 text-text-secondary text-sm"><svg class="w-4 h-4 text-success" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>Diskreter Versand</div>
          <div class="flex items-center gap-2 text-text-secondary text-sm"><svg class="w-4 h-4 text-success" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>Premium Qualität</div>
          <div class="flex items-center gap-2 text-text-secondary text-sm"><svg class="w-4 h-4 text-success" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>Schnelle Lieferung</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  {relatedProducts.length > 0 && (
    <section class="bg-secondary/30 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-black text-white mb-8">Ähnliche Produkte</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
          {relatedProducts.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<script define:vars={{ productData: { id: product.id, name: product.name, slug: product.slug, category: product.category, image: product.image, variations: product.variations } }}>
  // Variation selector
  const buttons = document.querySelectorAll('.variation-btn');
  const priceDisplay = document.getElementById('current-price');
  let selectedIndex = 0;

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => {
        b.classList.remove('border-gold', 'bg-gold/10', 'text-white');
        b.classList.add('border-white/10', 'text-text-secondary');
      });
      btn.classList.remove('border-white/10', 'text-text-secondary');
      btn.classList.add('border-gold', 'bg-gold/10', 'text-white');
      selectedIndex = parseInt(btn.dataset.index || '0');
      if (priceDisplay) {
        priceDisplay.textContent = `€${parseFloat(btn.dataset.price || '0').toFixed(2)}`;
      }
    });
  });

  // Add to cart
  document.getElementById('add-to-cart')?.addEventListener('click', () => {
    const variation = productData.variations[selectedIndex];
    const cartItem = {
      productId: productData.id,
      name: productData.name,
      slug: productData.slug,
      category: productData.category,
      weight: variation.weight,
      price: variation.price,
      quantity: 1,
    };

    const cart = JSON.parse(localStorage.getItem('cali_weed_cart') || '[]');
    const existingIndex = cart.findIndex((item) => item.productId === cartItem.productId && item.weight === cartItem.weight);
    
    if (existingIndex >= 0) {
      cart[existingIndex].quantity += 1;
    } else {
      cart.push(cartItem);
    }
    
    localStorage.setItem('cali_weed_cart', JSON.stringify(cart));
    
    // Update cart count
    const countEl = document.getElementById('cart-count');
    if (countEl) {
      const total = cart.reduce((sum, item) => sum + item.quantity, 0);
      countEl.textContent = total.toString();
      countEl.classList.remove('hidden');
    }

    // Visual feedback
    const addBtn = document.getElementById('add-to-cart');
    if (addBtn) {
      addBtn.textContent = '✓ Hinzugefügt!';
      addBtn.classList.add('bg-success');
      addBtn.classList.remove('bg-gold');
      setTimeout(() => {
        addBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"></path></svg> In den Warenkorb';
        addBtn.classList.remove('bg-success');
        addBtn.classList.add('bg-gold');
      }, 1500);
    }
  });
</script>
