---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import FAQ from '../components/FAQ.astro';
import { getProductsByCategory } from '../data/products';

const packProducts = getProductsByCategory('cali-weed-packs-kaufen');

const faqItems = [
  { question: "Was sind Cali Weed Packs?", answer: "Cali Weed Packs sind hochwertige, originalverpackte Cannabis-Blüten in authentischer Verpackung aus Kalifornien. Die Packs zeichnen sich durch einzigartige Designs und Premium-Qualität aus." },
  { question: "Wie erkenne ich originale Cali Packs?", answer: "Originale Cali Packs haben qualitativ hochwertige Verpackungen mit Hologrammen, einzigartigen Designs und oft QR-Codes zur Verifizierung. Die Blüten innen sind kompakt, stark riechend und mit dichter Trichom-Schicht." },
  { question: "Warum sind Cali Weed Packs teurer?", answer: "Der höhere Preis spiegelt die Premium-Qualität wider: handverlesene Genetiken, kontrollierter Anbau, aufwändige Trocknung und Aushärtung, sowie die authentische Verpackung. Das Ergebnis ist ein deutlich überlegenes Produkt." },
];
---
<Layout
  title="Cali Weed Packs Kaufen | Original Cali Packs Deutschland"
  description="Cali Weed Packs kaufen ✓ Original Cali Verpackungen ✓ Premium Blüten ✓ Wizard Trees, Jungle Boys & mehr ✓ Authentische Cali Packs bestellen"
  canonical="/cali-weed-packs"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary via-secondary to-accent py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-3xl md:text-5xl font-black text-white mb-6">Cali Weed Packs Kaufen</h1>
        <p class="text-text-secondary text-lg leading-relaxed">Entdecke originale Cali Weed Packs mit Premium-Blüten und authentischen Verpackungen. Handverlesen und in höchster Qualität.</p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-4xl">
      <h2 class="text-2xl font-black text-white mb-6">Was sind Cali Weed Packs?</h2>
      <p class="text-text-secondary leading-relaxed mb-4">Cali Weed Packs sind mehr als nur Cannabis-Verpackungen. Sie repräsentieren die höchste Stufe der Cannabis-Kultur aus Kalifornien. Jedes Pack enthält handverlesene Premium-Blüten und kommt in einer aufwändigen, oft limitierten Verpackung.</p>
      <p class="text-text-secondary leading-relaxed mb-8">Wenn du Cali Weed Packs kaufen möchtest, solltest du besonders auf Herkunft, Authentizität und Qualität achten. Bei uns findest du nur originale Packs von verifizierten Marken.</p>

      <h3 class="text-xl font-bold text-white mb-4">Warum Cali Weed Packs?</h3>
      <div class="grid md:grid-cols-3 gap-4 mb-8">
        <div class="bg-surface-light rounded-xl p-5 border border-white/5 text-center">
          <div class="text-3xl mb-3">🏷️</div>
          <h4 class="text-gold font-bold mb-2">Authentische Verpackung</h4>
          <p class="text-text-secondary text-sm">Original Designs mit Hologrammen und Sicherheitsmerkmalen</p>
        </div>
        <div class="bg-surface-light rounded-xl p-5 border border-white/5 text-center">
          <div class="text-3xl mb-3">💎</div>
          <h4 class="text-gold font-bold mb-2">Premium Qualität</h4>
          <p class="text-text-secondary text-sm">Handverlesene Topshelf-Blüten mit hohem THC-Gehalt</p>
        </div>
        <div class="bg-surface-light rounded-xl p-5 border border-white/5 text-center">
          <div class="text-3xl mb-3">🔒</div>
          <h4 class="text-gold font-bold mb-2">Frische Garantie</h4>
          <p class="text-text-secondary text-sm">Luftdicht versiegelt für optimale Frische und Aroma</p>
        </div>
      </div>

      <h3 class="text-xl font-bold text-white mb-4">Beliebte Cali Pack Marken</h3>
      <p class="text-text-secondary leading-relaxed mb-4">Zu den begehrtesten Cali Weed Pack Marken gehören Wizard Trees, Jungle Boys, Backpack Boyz, Cookies, Alien Labs und Connected Cannabis. Jede Marke hat ihren eigenen Stil und exklusive Genetiken.</p>
    </div>
  </section>

  <!-- Products -->
  <section class="bg-secondary/30 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-black text-white mb-8">Cali Weed Packs im Shop</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {packProducts.slice(0, 8).map((p) => <ProductCard product={p} />)}
      </div>
      <div class="text-center mt-8">
        <a href="/kategorie/cali-weed-packs-kaufen" class="inline-block bg-gold hover:bg-gold-dark text-primary font-bold px-8 py-3.5 rounded-xl transition-colors">Alle Packs ansehen</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-black text-white text-center mb-10">Häufige Fragen zu Cali Weed Packs</h2>
    <FAQ items={faqItems} />
  </section>
</Layout>
